---
import PluginLogo from './PluginLogo.astro';
---

<div class="header">
  <a href="/" class="site-logo">
    <PluginLogo height={18} />
  </a>
</div>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 0.5rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  :global(:root[data-theme='dark']) .site-logo {
    color: white;
  }

  :global(:root[data-theme='light']) .site-logo {
    color: #202020;
  }

  .site-logo:hover {
    opacity: 0.8;
  }

  @media (min-width: 50rem) {
    .header {
      display: none;
    }
  }
</style>
