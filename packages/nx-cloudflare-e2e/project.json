{
  "name": "nx-cloudflare-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/nx-cloudflare-e2e/src",
  "implicitDependencies": ["nx-cloudflare"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/nx-cloudflare-e2e/jest.config.ts",
        "runInBand": true
      },
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/jest.preset.js",
        "{workspaceRoot}/tools/scripts/start-local-registry.ts",
        "{workspaceRoot}/tools/scripts/stop-local-registry.ts",
        "{workspaceRoot}/tools/scripts/registry.d.ts",
        "{workspaceRoot}/.verdaccio/config.yml"
      ],
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "nx:noop"
    }
  }
}
