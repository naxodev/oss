{
  "$schema": "<%= schemaPath %>",
  "name": "<%= name %>",
  "main": "<%= main %>",
  "compatibility_date": "<%= compatibilityDate %>",<% if (nodejsCompat) { %>
  "compatibility_flags": ["nodejs_compat"],<% } %>
  // Full-stack Worker: static assets plus an API Worker. The ASSETS binding lets
  // your Worker fall through to static files (see Cloudflare static-assets docs).
  "assets": {
    "directory": "<%= assetsDir %>",
    "binding": "ASSETS"
  }
}
