{
  "$schema": "<%= schemaPath %>",
  "name": "<%= name %>",
  "compatibility_date": "<%= compatibilityDate %>",<% if (nodejsCompat) { %>
  "compatibility_flags": ["nodejs_compat"],<% } %>
  // Static-assets (SPA) Worker: serve a built single-page app from disk.
  "assets": {
    "directory": "<%= assetsDir %>",
    "not_found_handling": "single-page-application"
  }
}
