{
  "name": "@naxodev/nx-cloudflare",
  "version": "6.0.0",
  "description": "Nx plugin for Cloudflare",
  "homepage": "https://nx-cloudflare.naxo.dev/",
  "repository": {
    "type": "git",
    "url": "git@github.com:naxodev/oss.git",
    "directory": "packages/nx-cloudflare"
  },
  "license": "MIT",
  "dependencies": {
    "tslib": "^2.3.0",
    "@nx/devkit": "^23.0.0",
    "@nx/js": "^23.0.0",
    "jsonc-parser": "^3.3.0"
  },
  "peerDependencies": {
    "wrangler": "^4.0.0"
  },
  "keywords": [
    "nx",
    "cloudflare",
    "workers",
    "plugin"
  ],
  "contributors": [
    {
      "name": "Nacho Vazquez",
      "email": "nacho@naxo.dev",
      "url": "https://github.com/NachoVazquez"
    }
  ],
  "bugs": {
    "url": "https://github.com/naxodev/oss/issues?q=is:issue+is:open+sort:updated-desc"
  },
  "type": "commonjs",
  "main": "./src/index.js",
  "typings": "./src/index.d.ts",
  "generators": "./generators.json",
  "executors": "./executors.json",
  "nx-migrations": "./migrations.json",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./plugin": {
      "types": "./src/plugin.d.ts",
      "default": "./src/plugin.js"
    },
    "./package.json": "./package.json",
    "./generators.json": "./generators.json",
    "./migrations.json": "./migrations.json",
    "./src/generators/*/generator": "./src/generators/*/generator.js",
    "./src/generators/*/schema.json": "./src/generators/*/schema.json",
    "./src/generators/*/schema": "./src/generators/*/schema.d.ts",
    "./executors.json": "./executors.json",
    "./src/executors/*/executor": "./src/executors/*/executor.js",
    "./src/executors/*/schema.json": "./src/executors/*/schema.json",
    "./src/executors/*/schema": "./src/executors/*/schema.d.ts"
  }
}
