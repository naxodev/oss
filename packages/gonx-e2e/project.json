{
  "name": "gonx-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/gonx-e2e/src",
  "implicitDependencies": ["gonx", "e2e-utils"],
  "targets": {
    "e2e": {
      "command": "bun test --preload tools/scripts/e2e-bun-setup.ts packages/gonx-e2e/src",
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/tools/scripts/e2e-bun-setup.ts",
        "{workspaceRoot}/tools/scripts/start-local-registry.ts",
        "{workspaceRoot}/tools/scripts/stop-local-registry.ts",
        "{workspaceRoot}/tools/scripts/registry.d.ts",
        "{workspaceRoot}/.verdaccio/config.yml"
      ],
      "dependsOn": ["^build"]
    }
  }
}
