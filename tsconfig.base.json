{
  "compileOnSave": false,
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "sourceMap": true,
    "importHelpers": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2018",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "customConditions": ["@naxodev/source"]
  },
  "exclude": ["node_modules", "tmp"]
}
